{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          { "type": "command", "command": "sh ${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh ${CLAUDE_PLUGIN_ROOT}/hooks/session-resume.js" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__.+__notion-(create-pages|update-page)",
        "hooks": [
          { "type": "command", "command": "sh ${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh ${CLAUDE_PLUGIN_ROOT}/hooks/notion-page-record.js" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "sh ${CLAUDE_PLUGIN_ROOT}/hooks/run-node.sh ${CLAUDE_PLUGIN_ROOT}/hooks/friction-recover.js" }
        ]
      }
    ]
  }
}
