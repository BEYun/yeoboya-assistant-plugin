{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-resume.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__claude_ai_Notion__notion-(create-pages|update-page)",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/notion-page-record.js"
          }
        ]
      }
    ]
  }
}
